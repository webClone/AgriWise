// AgriWise - Algeria Agricultural Intelligence Platform
// Complete Database Schema - All Phases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  phone      String   @unique
  name       String
  nameAr     String?
  email      String?
  role       UserRole @default(SMALL_FARMER)
  wilaya     String
  wilayaCode String
  commune    String?
  language   String   @default("ar")
  isVerified Boolean  @default(false)
  isActive   Boolean  @default(true)

  // Role-specific profile data
  profile Json?

  // Relations
  farms         Farm[]
  pestReports   PestReport[]
  notifications Notification[]
  cooperative   CooperativeMember?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SMALL_FARMER
  MEDIUM_FARMER
  LARGE_FARMER
  COOPERATIVE_MANAGER
  AGRONOMIST
  INPUT_SUPPLIER
  TRANSPORTER
  STORAGE_OPERATOR
  RESEARCHER
  LOCAL_GOV
  NATIONAL_GOV
  ADMIN
}

model OtpCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

// ============================================
// FARM & PLOT MANAGEMENT
// ============================================

model Farm {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  nameAr String?

  // Location
  latitude  Float?
  longitude Float?
  wilaya    String
  commune   String?
  address   String?
  geoJson   Json? // Farm boundary polygon

  // Farm details
  totalArea      Float // hectares
  waterSource    WaterSource?
  irrigationType IrrigationType?
  soilType       SoilType?

  // Equipment inventory (Structured)
  equipment Equipment[]

  plots  Plot[]
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plot {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  nameAr String?
  area   Float // hectares

  // Detailed Characteristics
  soilType   SoilType?
  irrigation IrrigationType?
  geoJson    Json? // Plot boundary polygon

  // [NEW] Enhanced Fields
  perimeter           Float?
  ownership           String?
  irrigationDistrict  String?
  physicalConstraints String[]

  // Lifecycle & History
  cropCycles CropCycle[]

  // [NEW] User Inputs Relations
  photos       PlotPhoto[]
  cameras      IPCamera[]
  soilAnalyses SoilAnalysis[]
  sensors      Sensor[]

  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// [NEW] Visual Ground Truth
model PlotPhoto {
  id    String    @id @default(auto()) @map("_id") @db.ObjectId
  url   String
  type  PhotoType
  date  DateTime
  tags  String[]
  notes String?

  plot   Plot   @relation(fields: [plotId], references: [id], onDelete: Cascade)
  plotId String @db.ObjectId

  createdAt DateTime @default(now())
}

enum PhotoType {
  CROP
  SOIL
  OVERVIEW
  DAMAGE
  OTHER
}

model IPCamera {
  id     String       @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  url    String
  type   CameraType
  status DeviceStatus @default(OFFLINE)

  plot   Plot   @relation(fields: [plotId], references: [id], onDelete: Cascade)
  plotId String @db.ObjectId

  createdAt DateTime @default(now())
}

enum CameraType {
  FIXED
  PTZ
  DRONE_FEED
}

// [NEW] Soil & Physical Properties
model SoilAnalysis {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  date    DateTime
  fileUrl String?

  // Sampling context
  depthFrom        Int? // Start depth in cm (e.g. 0)
  depthTo          Int? // End depth in cm (e.g. 30)
  samplingLocation String? // "Whole Plot", "Zone A", "GPS: 36.75, 3.04" etc.
  notes            String?

  // Parsed Data
  ph            Float?
  ec            Float?
  organicMatter Float?
  nitrogen      Float?
  phosphorus    Float?
  potassium     Float?
  texture       String?

  plot   Plot   @relation(fields: [plotId], references: [id], onDelete: Cascade)
  plotId String @db.ObjectId

  createdAt DateTime @default(now())
}

// [NEW] Sensors & Infrastructure
model Sensor {
  id       String       @id @default(auto()) @map("_id") @db.ObjectId
  type     SensorType
  vendor   String?
  deviceId String       @unique
  lastSync DateTime?
  status   DeviceStatus @default(ACTIVE)
  battery  Float? // Latest battery level 0-100%
  rssi     Int? // Latest signal strength in dBm
  apiKey   String? // Device authentication key

  plot   Plot   @relation(fields: [plotId], references: [id], onDelete: Cascade)
  plotId String @db.ObjectId

  readings SensorReading[]

  createdAt DateTime @default(now())
}

model SensorReading {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  sensor   Sensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)
  sensorId String @db.ObjectId

  // Core telemetry
  temperature  Float?
  humidity     Float?
  soilMoisture Float?
  ec           Float? // Electrical conductivity
  windSpeed    Float?
  rainfall     Float?

  // Device meta snapshot
  battery Float?
  rssi    Int?

  timestamp DateTime @default(now())
}

enum SensorType {
  MOISTURE
  TEMP
  EC
  WEATHER
  OTHER
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  MAINTENANCE
}

model Equipment {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      EquipmentType
  condition String? // new, good, fair, poor, broken
  quantity  Int           @default(1)

  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId String @db.ObjectId
}

enum WaterSource {
  WELL
  DAM
  RIVER
  RAINFED
  DESALINATED
}

enum IrrigationType {
  DRIP
  SPRINKLER
  PIVOT
  FLOOD
  RAINFED
}

enum SoilType {
  CLAY
  SANDY
  LOAM
  SILT
  PEAT
  CHALKY
}

enum EquipmentType {
  TRACTOR
  HARVESTER
  PUMP
  IRRIGATION_SYSTEM
  PLOW
  SPRAYER
  TRUCK
  STORAGE
  OTHER
}

// ============================================
// CROP LIFECYCLE MANAGEMENT
// ============================================

model CropCycle {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Crop info
  cropCode   String
  cropNameAr String?
  variety    String?

  // Timeline
  plantDate       DateTime
  expectedHarvest DateTime?
  actualHarvest   DateTime?
  status          CropStatus @default(PLANNED)

  // Yield tracking
  estimatedYield Float? // kg/hectare
  actualYield    Float?
  yieldQuality   String? // excellent, good, average, poor

  // Cost tracking
  totalCost Float?
  revenue   Float?

  notes String?

  // Relations
  tasks        CropTask[]
  inputs       InputLog[]
  observations CropObservation[]

  plot   Plot   @relation(fields: [plotId], references: [id], onDelete: Cascade)
  plotId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CropStatus {
  PLANNED
  PLANTED
  GROWING
  FLOWERING
  FRUITING
  READY_TO_HARVEST
  HARVESTED
  FAILED
}

model CropTask {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  type        TaskType
  title       String
  titleAr     String?
  description String?
  dueDate     DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?

  cropCycle   CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)
  cropCycleId String    @db.ObjectId
  createdAt   DateTime  @default(now())
}

enum TaskType {
  PLANTING
  IRRIGATION
  FERTILIZING
  PEST_CONTROL
  PRUNING
  WEEDING
  HARVEST
  SOIL_PREP
  OTHER
}

model InputLog {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  type      InputType
  name      String
  nameAr    String?
  brand     String?
  quantity  Float
  unit      String // kg, liters, units
  cost      Float?
  currency  String    @default("DZD")
  appliedAt DateTime
  notes     String?

  cropCycle   CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)
  cropCycleId String    @db.ObjectId
  createdAt   DateTime  @default(now())
}

enum InputType {
  SEED
  FERTILIZER
  PESTICIDE
  HERBICIDE
  FUNGICIDE
  WATER
  FUEL
  LABOR
  EQUIPMENT
  OTHER
}

model CropObservation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String // growth, health, pest, disease, weather_impact
  title       String
  description String?
  severity    String? // info, warning, critical
  photos      String[]

  cropCycle   CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)
  cropCycleId String    @db.ObjectId
  createdAt   DateTime  @default(now())
}

// ============================================
// WEATHER & CLIMATE
// ============================================

model WeatherCache {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  wilayaCode String
  latitude   Float
  longitude  Float
  data       Json // Cached weather data
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime

  @@unique([wilayaCode])
}

model WeatherAlert {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  wilayaCode     String
  type           AlertType
  severity       Severity
  titleAr        String
  titleFr        String?
  messageAr      String
  messageFr      String?
  recommendation String?
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@index([wilayaCode, isActive])
}

enum AlertType {
  FROST
  HEAT_WAVE
  HEAVY_RAIN
  DROUGHT
  WIND
  SANDSTORM
  HAIL
  FLOOD
}

enum Severity {
  INFO
  WARNING
  CRITICAL
}

// ============================================
// PEST & DISEASE NETWORK
// ============================================

model PestReport {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  type   String // pest, disease, unknown
  name   String?
  nameAr String?

  // Location
  latitude   Float
  longitude  Float
  wilayaCode String
  commune    String?

  // Details
  severity     Severity
  description  String?
  photos       String[]
  cropAffected String?
  spreadArea   Float? // hectares

  // Status
  status     ReportStatus @default(REPORTED)
  verifiedBy String?      @db.ObjectId
  treatment  String?

  reporter   User   @relation(fields: [reporterId], references: [id])
  reporterId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([wilayaCode, status])
}

enum ReportStatus {
  REPORTED
  VERIFIED
  INVESTIGATING
  RESOLVED
  FALSE_ALARM
}

model PestAlert {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  pestName   String
  pestNameAr String?
  type       String // pest, disease

  wilayaCode String
  severity   Severity

  titleAr        String
  messageAr      String
  treatment      String?
  preventionTips String[]

  affectedCrops String[]
  reportCount   Int      @default(1)

  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?

  createdAt DateTime @default(now())

  @@index([wilayaCode, isActive])
}

// ============================================
// MARKET & PRICES
// ============================================

model MarketPrice {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  cropCode   String
  cropNameAr String
  price      Float
  unit       String // kg, quintal, ton
  currency   String @default("DZD")

  market     String // market name
  wilayaCode String

  priceType  String // wholesale, retail, farm_gate
  recordedAt DateTime @default(now())
  source     String? // who reported

  @@index([cropCode, wilayaCode])
  @@index([recordedAt])
}

model MarketTrend {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  cropCode   String
  wilayaCode String? // null for national

  period      String // daily, weekly, monthly
  avgPrice    Float
  minPrice    Float
  maxPrice    Float
  priceChange Float // percentage
  trend       String // up, down, stable

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())

  @@index([cropCode, period])
}

// ============================================
// COOPERATIVES
// ============================================

model Cooperative {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  nameAr String?

  wilaya  String
  commune String?
  address String?
  phone   String?

  // Stats (denormalized for performance)
  memberCount Int   @default(0)
  totalArea   Float @default(0)

  members CooperativeMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CooperativeMember {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  role     String // manager, member
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.ObjectId

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id])
  cooperativeId String      @db.ObjectId
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  type      String // weather, pest, task, market, system
  title     String
  titleAr   String?
  message   String
  messageAr String?

  priority String    @default("normal") // low, normal, high, urgent
  isRead   Boolean   @default(false)
  readAt   DateTime?

  data      Json? // Additional data
  actionUrl String? // Deep link

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @db.ObjectId

  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

// ============================================
// REFERENCE DATA
// ============================================

// DYNAMIC CROP REFERENCE DATA
model Crop {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  code     String  @unique // wheat, barley, tomato
  nameAr   String
  nameFr   String
  nameEn   String
  icon     String?
  category String // cereals, fruits, vegetables, legumes, tree_crops

  // Growth Cycle & Stages (Dynamic)
  // Example: [{ stage: "planting", startDay: 0, endDay: 7 }, { stage: "vegetative", startDay: 8, endDay: 45 }]
  stages Json?

  // Detailed Requirements
  waterRequirements Json? // { early: "low", mid: "high", late: "low" }
  nutrientNeeds     Json? // { N: "high", P: "medium", K: "medium" }
  soilPreferences   SoilType[]
  minTemp           Float?
  maxTemp           Float?

  // Seasonality by Region Type
  // { "mediterranean": { plant: [10, 11], harvest: [5, 6] }, "saharan": { ... } }
  seasonality Json?

  // Best Practices & Risks
  recommendations Json?
  commonPests     String[]
  commonDiseases  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wilaya {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  code      String    @unique
  nameAr    String
  nameFr    String
  nameEn    String
  latitude  Float
  longitude Float
  climate   String // mediterranean, semi-arid, arid, saharan
  communes  Commune[]
}

model Commune {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  code     String @unique
  nameAr   String
  nameFr   String
  wilaya   Wilaya @relation(fields: [wilayaId], references: [id])
  wilayaId String @db.ObjectId
}

// ============================================
// ANALYTICS & AGGREGATIONS (for dashboards)
// ============================================

model RegionalStats {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  wilayaCode String
  period     String // daily, weekly, monthly, yearly

  // Farm stats
  farmCount   Int
  farmerCount Int
  totalArea   Float

  // Crop stats
  cropDistribution Json // { wheat: 1000, barley: 500, ... }

  // Yield stats
  avgYield Json? // { wheat: 25, barley: 20, ... }

  // Risk indicators
  pestReports   Int
  weatherAlerts Int

  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())

  @@unique([wilayaCode, period, startDate])
}
